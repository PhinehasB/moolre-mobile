{
  "expo": {
    "name": "klare-mobile",
    "slug": "klare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "klaremobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/klare-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F6E56",
          "dark": {
            "image": "./assets/images/klare-logo.png",
            "imageWidth": 200,
            "backgroundColor": "#0F6E56"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0F6E56"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27cba6c0-de16-4b7e-9c4b-5497aca172c1"
      }
    },
    "owner": "joeboy77"
  }
}
